MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/querious?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-key-here
JWT_EXPIRY=7d
PORT=5000
NODE_ENV=development
MOCK_AI=false

# CORS — set to your deployed frontend URL in production (no trailing slash!)
# Example for this project:
FRONTEND_URL=https://querious-seven.vercel.app

# AI Provider — swap these three vars to change provider, no code changes needed
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-oss-20b:free

# Provider examples:
# OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1, AI_MODEL=openai/gpt-oss-20b:free
# Groq:       AI_BASE_URL=https://api.groq.com/openai/v1, AI_MODEL=llama-3.3-70b-versatile
# Grok:       AI_BASE_URL=https://api.x.ai/v1, AI_MODEL=grok-3-mini-fast
# OpenAI:     AI_BASE_URL=https://api.openai.com/v1, AI_MODEL=gpt-4o-mini
